[Unit]
Description=TCS RFP Response Drafter FastAPI Application
After=network.target

[Service]
User=e2725427
Group=e2725427
WorkingDirectory=/data/acp-agents/response-drafter
Environment="PATH=/data/acp-agents/response-drafter/venv/bin"
Environment="PYTHONUNBUFFERED=1"
ExecStart=/data/acp-agents/response-drafter/venv/bin/gunicorn \
  -w 4 \
  -k uvicorn.workers.UvicornWorker \
  response_drafter_agent.main:app \
  --bind 0.0.0.0:8006 \
  --access-logfile - \
  --error-logfile -
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
