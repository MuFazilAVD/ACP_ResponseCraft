# Secrets only.
# Runtime defaults such as model names, URLs, prompt labels, transports, and
# generation settings are tracked in response_drafter_agent/settings.py.

# LLM gateway credentials, if the standard gateway requires authentication.
LLM_API_KEY=
OPENAI_API_KEY=
LITELLM_MASTER_KEY=

# Langfuse PromptHub and trace credentials.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# OTLP exporter token. The endpoint and auth header format are tracked in code.
OTLP_API_KEY=

# ACP/MCP gateway credentials.
ACP_AGENT_API_KEY=
MCP_API_KEY=

# Agent-specific enterprise API credentials, if your MCP bridge requires them.
PROPOSAL_KNOWLEDGE_API_KEY=
APPROVED_CAPABILITY_LIBRARY_API_KEY=
SECURITY_COMPLIANCE_LIBRARY_API_KEY=

# AWS DynamoDB credentials for invocation tracking (table: ACP_RC_ResponseDrafter).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
DYNAMODB_REGION=ap-south-1
